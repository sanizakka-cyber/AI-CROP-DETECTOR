# Paths are relative to the git repository root (not this directory).
# EAS finds this file in the project dir but resolves paths from the repo root.

# Non-mobile directories
msas-system/
web/
ai-engine/
deploy/
docs/

# Installed/generated — EAS rebuilds these server-side
mobile/node_modules/
mobile/.expo/

# Exclude entire android dir so EAS runs expo prebuild fresh
mobile/android/

# iOS build artifacts
mobile/ios/Pods/
mobile/ios/build/
