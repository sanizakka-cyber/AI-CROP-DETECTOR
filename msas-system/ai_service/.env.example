# MSAS AI Service Configuration
# Copy this file to .env and fill in your API keys

# Google Cloud Vision API Key (for object classification & rejection)
# Get yours free at: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# Hugging Face API Token (for plant disease model)
# Get yours free at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here

# Port the Flask service runs on
PORT=5001
